# ───────────────────────────────────────────────────────
# DBT Platform — Environment Configuration
# Copy to .env and fill in real values before starting.
# ───────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════
# 1. Django — Security & Debug
# ═══════════════════════════════════════════════════════
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True

# ═══════════════════════════════════════════════════════
# 2. Internal Service Addresses
#    These point to services running on the same host or
#    within the same Docker network.  They are NOT exposed
#    to browsers and should remain localhost / container
#    hostnames regardless of deployment environment.
# ═══════════════════════════════════════════════════════

# ── MongoDB (Alibaba Cloud self-built) ──
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_NAME=dbt_platform
MONGODB_USER=dbt_app
MONGODB_PASSWORD=change-me

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── MinIO ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=dbt-platform
MINIO_SECURE=False

# ── Qdrant ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=dbt_knowledge

# ═══════════════════════════════════════════════════════
# 3. External Access — Cross-Device & Production
#    These MUST be updated when accessing from another
#    device or deploying to production.
#    Dev (localhost only): keep as shown.
#    Production: point ALL to https://<domain>:10443
# ═══════════════════════════════════════════════════════

# Hosts the Django server should serve.
# Dev:     DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Prod:    DJANGO_ALLOWED_HOSTS=genaidbt.top,www.genaidbt.top
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base URL used to generate absolute links in exports,
# reports, and emails.  Browsers must be able to resolve
# this address from their network.
# Dev:     EXTERNAL_BASE_URL=http://localhost:8000
# Prod:    EXTERNAL_BASE_URL=https://genaidbt.top
EXTERNAL_BASE_URL=http://localhost:8000

# Origins trusted by Django for CSRF validation.
# IMPORTANT for production: add https://genaidbt.top
# Dev:     CSRF_TRUSTED_ORIGINS=
# Prod:    CSRF_TRUSTED_ORIGINS=https://genaidbt.top,https://www.genaidbt.top
CSRF_TRUSTED_ORIGINS=

# ═══════════════════════════════════════════════════════
# 4. External APIs
# ═══════════════════════════════════════════════════════

# ── DeepSeek (LLM) ──
# DeepSeek V4 Flash — OpenAI-compatible API
DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Image Generation — Volcengine Ark Agent Plan (Seedream 5.0 Lite) ──
# Must use Agent Plan dedicated API Key + /api/plan/v3 base URL.
# Console: 火山方舟 → 开通管理 → Agent Plan
ARK_AGENT_PLAN_API_KEY=change-me
ARK_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
ARK_IMAGE_MODEL=doubao-seedream-5.0-lite
ARK_IMAGE_SIZE=2K

# ── MiniMax (deprecated) ──
MINIMAX_API_KEY=change-me
MINIMAX_BASE_URL=https://api.minimaxi.com

# ── Volcengine (火山引擎) — ASR + TTS ──
# API Key is shared across volcengine speech services.
# Get from https://console.volcengine.com → 语音技术 → API Key管理 (new console)
VOLCENGINE_API_KEY=change-me

# Volcengine TTS V3 (豆包语音合成模型2.0)
# Uses new console auth: X-Api-Key + X-Api-Resource-Id (no appid needed)
# Speaker for seed-tts-2.0 model
VOLCENGINE_TTS_SPEAKER=zh_female_xueayi_saturn_bigtts

# ═══════════════════════════════════════════════════════
# 5. Celery (broker / result backend)
# ═══════════════════════════════════════════════════════
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Image generation concurrency (interactive teaching vs batch prefetch)
IMAGE_MAX_CONCURRENT=4
IMAGE_INTERACTIVE_MAX_CONCURRENT=3
IMAGE_BATCH_MAX_CONCURRENT=1
IMAGE_SLOT_WAIT_TIMEOUT_SECONDS=120
IMAGE_SLOT_WAIT_INTERVAL_SECONDS=3
TEACHING_IMAGE_MAX_PER_STEP=1
TEACHING_IMAGE_MAX_PER_SESSION=3
TEST_IMAGE_MAX_PER_TEST=2

# ═══════════════════════════════════════════════════════
# 7. Load testing (scripts/loadtest_15users.py)
#    Never run against production without explicit opt-in.
# ═══════════════════════════════════════════════════════
# LOADTEST_BASE_URL=http://localhost:8000
# LOADTEST_ALLOW_RUN=1
# LOADTEST_RESET_ADMIN=1
# LOADTEST_ADMIN_PASS=admin123456
# LOADTEST_BLOCKED_HOSTS=genaidbt.top,www.genaidbt.top

# ═══════════════════════════════════════════════════════
# 6. Docker Compose Overrides
#    Only needed when using docker-compose.yml.
# ═══════════════════════════════════════════════════════
MONGODB_ROOT_USER=root
MONGODB_ROOT_PASSWORD=rootpassword
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
